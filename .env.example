# ==============================================================================
# AI Deployer - Ortam Değişkenleri Şablonu (.env)
# ==============================================================================

# Genel Ayarlar
TIMEZONE=Europe/Istanbul

# Open WebUI Ayarları
# Rastgele anahtar üretmek için terminalde çalıştırın: openssl rand -hex 32
WEBUI_SECRET_KEY=ayarlanacak_rastgele_gizli_anahtar

# PostgreSQL Veritabanı Ayarları (n8n kullanımı için)
POSTGRES_DB=n8n_automation_db
POSTGRES_USER=n8n_db_user
POSTGRES_PASSWORD=guvenli_bir_veritabani_sifresi

# n8n Yapılandırma Ayarları
N8N_HOST=n8n.yourdomain.com
N8N_PROTOCOL=https
N8N_SECURE_COOKIE=true

# Webhook URL (n8n'in dış servislerden tetik alabilmesi için kritik)
N8N_WEBHOOK_URL=https://n8n.yourdomain.com/
