# ============================================
# Yerel AI Deployment - Ortam Değişkenleri
# ============================================

# Domain ve SSL
CERTBOT_DOMAIN=204.168.255.122
CERTBOT_EMAIL=admin@aideployer.local
DOMAIN_NAME=204.168.255.122

# Nginx SSL
N8N_HOST=204.168.255.122
N8N_PROTOCOL=https
N8N_SECURE_COOKIE=true
N8N_WEBHOOK_URL=https://204.168.255.122/n8n/webhook

# PostgreSQL (n8n Database)
POSTGRES_DB=n8n_db
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=Pass.123

# Open WebUI
WEBUI_SECRET_KEY=your-super-secret-key-change-this-in-production-$(date +%s)
WEBUI_ADMIN_USER=burak
WEBUI_ADMIN_PASSWORD=Pass.123

# n8n Admin
N8N_ADMIN_USER=burak
N8N_ADMIN_PASSWORD=Pass.123
N8N_ADMIN_EMAIL=burak@aideployer.local

# Genel Ayarlar
TIMEZONE=Europe/Istanbul
COMPOSE_PROJECT_NAME=aideployer

# Ollama
OLLAMA_MODEL=mistral
OLLAMA_NUM_PARALLEL=1
OLLAMA_NUM_THREAD=4

# Redis
REDIS_PASSWORD=redis-secure-pass-$(date +%s)

# Backup ve Logging
LOG_LEVEL=info
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400
